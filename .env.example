# =============================================================================
# .env.example – Sample file demonstrating secrets env-scanner detects
#
# IMPORTANT: This file uses safe placeholder or clearly-fake values.
#   - Values wrapped in <ANGLE_BRACKETS> are format examples – replace them.
#   - Other values use fictional hostnames/passwords.
#   - Copy this file to .env and fill in real credentials (keep .env gitignored).
#
# Run:  env-scanner scan .env.example
# =============================================================================

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=MyApplication
APP_ENV=development
APP_DEBUG=true
APP_PORT=8000

# ─── AWS ──────────────────────────────────────────────────────────────────────
# Format: AWS_ACCESS_KEY_ID=AKIA[0-9A-Z]{16}
# Example (canonical AWS docs example – triggers env-scanner):
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_DEFAULT_REGION=us-east-1
AWS_S3_BUCKET=my-app-bucket

# ─── Database connections ──────────────────────────────────────────────────────
# CRITICAL: These URLs embed credentials directly – rotate immediately if leaked
DATABASE_URL=postgres://appuser:Xk9#mP2qR8vL@db.example-fake.internal:5432/production_db
MYSQL_URL=mysql://root:Tz3!nQ7wE5sA@db.example-fake.internal:3306/app_db
MONGO_URI=mongodb+srv://dbadmin:Wm6@cluster.example-fake.mongodb.net/mydb
REDIS_URL=redis://:Hn4$kJ2pM9xC@cache.example-fake.internal:6379/0
AMQP_URL=amqps://mq_user:Lp8!vD3rS6tG@mq.example-fake.internal:5671/app_vhost

# ─── Passwords (generic) ──────────────────────────────────────────────────────
# CRITICAL: Plain-text passwords should never be committed
PASSWORD=Bq7!nK3mX9pR2sW
DB_PASS=Tz4#vH8jL2qN6yD
SECRET=Kw9!rM5xP3nB7cF

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Format: sk_live_[a-zA-Z0-9]{24+}  |  pk_live_[a-zA-Z0-9]{24+}
# Replace with your actual Stripe keys from dashboard.stripe.com
STRIPE_SECRET_KEY=sk_live_<YOUR_STRIPE_LIVE_SECRET_KEY>
STRIPE_PUBLISHABLE_KEY=pk_live_<YOUR_STRIPE_LIVE_PUBLISHABLE_KEY>
STRIPE_TEST_SECRET_KEY=sk_test_<YOUR_STRIPE_TEST_SECRET_KEY>
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_STRIPE_WEBHOOK_SECRET>

# ─── GitHub ───────────────────────────────────────────────────────────────────
# Format: ghp_[A-Za-z0-9]{36}  (Personal Access Token)
# Replace with a token from github.com/settings/tokens
GITHUB_TOKEN=ghp_<YOUR_GITHUB_PERSONAL_ACCESS_TOKEN_36CHARS>
GH_TOKEN=gho_<YOUR_GITHUB_OAUTH_TOKEN_36CHARS>

# ─── Slack ────────────────────────────────────────────────────────────────────
# Format: xoxb-[0-9]+-[0-9]+-[a-zA-Z0-9]+  (Bot Token)
# Replace with tokens from api.slack.com/apps
SLACK_BOT_TOKEN=xoxb-<YOUR_SLACK_BOT_TOKEN>
SLACK_USER_TOKEN=xoxp-<YOUR_SLACK_USER_TOKEN>
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<T_ID>/<B_ID>/<WEBHOOK_KEY>

# ─── Google / GCP ─────────────────────────────────────────────────────────────
# Format: AIza[0-9A-Za-z\-_]{35}
# Replace with a key from console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=AIza<YOUR_GOOGLE_API_KEY_35CHARS>
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ─── Twilio ───────────────────────────────────────────────────────────────────
# Format: ACCOUNT_SID=AC[a-f0-9]{32}  |  AUTH_TOKEN=[a-f0-9]{32}
TWILIO_ACCOUNT_SID=AC<YOUR_32_HEX_CHAR_ACCOUNT_SID_HERE>
TWILIO_AUTH_TOKEN=<YOUR_32_HEX_CHAR_AUTH_TOKEN_HERE>

# ─── SendGrid ─────────────────────────────────────────────────────────────────
# Format: SG.[A-Za-z0-9_-]{22}.[A-Za-z0-9_-]{43}
SENDGRID_API_KEY=SG.<YOUR_SENDGRID_API_KEY>

# ─── Azure ────────────────────────────────────────────────────────────────────
AZURE_STORAGE_ACCOUNT_KEY=<YOUR_AZURE_STORAGE_ACCOUNT_KEY_BASE64>
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=mystorageaccount;AccountKey=<YOUR_KEY>;EndpointSuffix=core.windows.net
AZURE_CLIENT_SECRET=<YOUR_AZURE_CLIENT_SECRET>

# ─── Datadog ──────────────────────────────────────────────────────────────────
# Format: [a-f0-9]{32}  – triggers env-scanner generic hex key detector
DATADOG_API_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6
DATADOG_APP_KEY=a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0

# ─── New Relic ────────────────────────────────────────────────────────────────
NEW_RELIC_LICENSE_KEY=ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmn

# ─── Mailgun ──────────────────────────────────────────────────────────────────
MAILGUN_API_KEY=key-a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6

# ─── JWT ──────────────────────────────────────────────────────────────────────
# CRITICAL: JWT secrets sign all user tokens – rotation invalidates all sessions
JWT_SECRET=Vn8#mK4pQ2xR7tL3sB9wJ1hD6cE0fG5a
JWT_SIGNING_KEY=Zq3!yP6rN1vT9mX4kH7sB0wC5jF2dL8e

# ─── NPM ──────────────────────────────────────────────────────────────────────
# Format: npm_[A-Za-z0-9]{36}
NPM_TOKEN=npm_<YOUR_NPM_AUTH_TOKEN_36CHARS>

# ─── Heroku ───────────────────────────────────────────────────────────────────
# Format: UUID [8-4-4-4-12 hex]
HEROKU_API_KEY=<YOUR-HEROKU-API-KEY-UUID-FORMAT>

# ─── DigitalOcean ─────────────────────────────────────────────────────────────
DO_TOKEN=<YOUR_64_HEX_CHAR_DIGITALOCEAN_PAT>

# ─── Shopify ──────────────────────────────────────────────────────────────────
SHOPIFY_ACCESS_TOKEN=shpat_<YOUR_SHOPIFY_ACCESS_TOKEN_32CHARS>

# ─── Okta ─────────────────────────────────────────────────────────────────────
OKTA_API_TOKEN=00<YOUR_OKTA_API_TOKEN_40CHARS>

# ─── PagerDuty ────────────────────────────────────────────────────────────────
PAGERDUTY_API_KEY=Mn7$kR3pX9vL2sQ8wH4jB1cD6tE0fA5y

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_PASSWORD=Gp5!qN2mR8xL4tK7vB0sJ3hC9wD6eF1a

# ─── Encryption ───────────────────────────────────────────────────────────────
ENCRYPTION_KEY=dGhpcyBpcyBhIGZha2UgZW5jcnlwdGlvbiBrZXkgZm9yIGRlbW9ucw==
AES_KEY=Qr4!nM7vK2pX9tS5wL8jH3bC0yD6eG1f

# ─── Generic API Keys / Tokens ────────────────────────────────────────────────
API_KEY=Wt6#mJ9rP3xN7sK2vL8qB5cH1eA0fD4g
ACCESS_TOKEN=Xk8!vR4mQ1tP9nL7sH3bC6jA2wE5fG0d
AUTH_TOKEN=Zp2#nK7xM5rQ9tL3vJ8sB1wC4hD0eF6a

# ─── Safe / non-sensitive values (should NOT trigger findings) ────────────────
APP_VERSION=1.0.0
LOG_LEVEL=INFO
MAX_CONNECTIONS=10
ENABLE_CACHE=true
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ORIGINS=http://localhost:3000
